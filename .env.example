# API-Football v3 key — required for live match data
# Get yours at: https://dashboard.api-football.com/ (free tier: ~100 requests/day)
API_SPORTS_KEY=your_key_here

# WalletConnect Cloud project ID — required for mobile WalletConnect support
# Get yours at: https://cloud.walletconnect.com/ (free)
# Leave empty to disable WalletConnect (injected browser wallet still works)
WC_PROJECT_ID=
